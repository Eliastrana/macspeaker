# Copy this file to .env.local and fill in the values from your Supabase project.
# Supabase dashboard → Project Settings → API
#
# Both values are browser-safe (the anon key is designed to be public).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Passcode for the recorder gate. Any length (4 or 6 digits feels most native).
# NOTE: this is a soft gate — it ships in the browser bundle, so treat it as
# "keep casual strangers out", not real security. Defaults to 1234 if unset.
NEXT_PUBLIC_PIN=1234
